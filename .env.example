# Runtime environment. Set to "production" on Railway so the app never reads a
# .env file from disk — all variables are injected by the platform instead.
# Leave unset (defaults to "development") for local Docker Compose usage.
ENV=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/portfolio

# Resend (transactional email — used by POST /contact)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_API_URL=https://api.resend.com/emails
RESEND_FROM_EMAIL=portfolio@yourdomain.com

# CONTACT_TO_EMAIL and CORS_ORIGINS accept a JSON array or a comma-separated
# string. The JSON form is required by pydantic-settings when a value contains
# characters like `,` that would be ambiguous in CSV.
#   JSON: ["a@b.com","c@d.com"]
#   CSV:  a@b.com,c@d.com
CONTACT_TO_EMAIL=["you@youremail.com"]
# Required — the app refuses to start if this is empty. In production, set to
# your deployed frontend origin only (no trailing slash):
#   ["https://www.yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Must match R2_PUBLIC_URL in the backend config.
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev

# Shared secret for the on-demand ISR webhook at POST /api/revalidate.
# Generate with: openssl rand -hex 32
REVALIDATION_SECRET=replace_with_random_64_char_hex

# Shared secret for admin write endpoints (image upload/delete).
# Generate with: openssl rand -hex 32
ADMIN_SECRET=replace_with_random_64_char_hex

# Cloudflare R2 — S3-compatible object storage for project cover images.
# Account ID: Cloudflare dashboard → Overview → right sidebar.
R2_ACCOUNT_ID=your_cloudflare_account_id
# API token: R2 → Manage R2 API tokens → Create token (Object Read & Write).
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=portfolio-images
# Either enable "Public access" on the bucket (r2.dev URL) or connect a custom domain.
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev
